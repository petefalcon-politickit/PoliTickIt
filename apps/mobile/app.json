{
  "expo": {
    "name": "PoliTickIt",
    "slug": "politickit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.svg",
    "scheme": "politickit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/favicon.svg",
        "backgroundImage": "./assets/images/favicon.svg",
        "monochromeImage": "./assets/images/favicon.svg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.politickit"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.svg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8fa54eb4-7a36-4f19-a972-6a9709aab48d"
      }
    }
  }
}
