using System;
using System.Collections.Generic;
using System.Net.Http;
using System.Net.Http.Json;
using System.Threading.Tasks;
using System.Text.Json;
using PoliTickIt.Domain.Interfaces;
using PoliTickIt.Domain.Models;
using Microsoft.Extensions.Options;
using Microsoft.Extensions.Caching.Memory;
using PoliTickIt.Ingestion.Configuration;

namespace PoliTickIt.Ingestion.Providers;

/// <summary>
/// Autonomous Processor for Federal Grants (Infrastructure, Education, Research).
/// Monitors SAM.gov and threads them down to District context.
/// Scenario B Implementation: Infrastructure Grant -> District ROI.
/// </summary>
public class GrantPulseProvider : BaseOracleProvider
{
    private readonly OracleSettings.GrantsApiSettings _settings;
    private readonly IMemoryCache _cache;

    public override string ProviderName => "Regional.Grant.Pulse.Engine";

    public GrantPulseProvider(
        HttpClient httpClient,
        IContextEnrichmentProcessor cep,
        IOptions<OracleSettings> options,
        IMemoryCache cache) : base(httpClient, cep)
    {
        _settings = options.Value.Grants;
        _cache = cache;
        
        HttpClient.BaseAddress = new Uri(_settings.SamBaseUrl);
        HttpClient.Timeout = TimeSpan.FromSeconds(_settings.TimeoutSeconds);
    }

    public override async Task<IEnumerable<PoliSnap>> FetchLatestSnapsAsync()
    {
        var snaps = new List<PoliSnap>();

        try
        {
            // Fetch active grant opportunities from SAM.gov
            var grants = await FetchActiveGrantsAsync();
            foreach (var grant in grants)
            {
                snaps.Add(MapToGrantInsightPivot(grant));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"GrantPulse Provider Error: {ex.Message}");
        }

        return snaps;
    }

    /// <summary>
    /// Fetches current open grant opportunities from SAM.gov API.
    /// Filters for opportunities with funding > $1M.
    /// </summary>
    private async Task<List<GrantOpportunity>> FetchActiveGrantsAsync()
    {
        var grants = new List<GrantOpportunity>();

        try
        {
            // Check cache first
            if (_settings.EnableCaching)
            {
                var cacheKey = "sam_active_grants";
                if (_cache.TryGetValue(cacheKey, out List<GrantOpportunity>? cached))
                {
                    return cached ?? new List<GrantOpportunity>();
                }
            }

            // SAM.gov API query for open opportunities
            // Endpoint: /v1/opportunities/search
            var query = $"/search?api_key={_settings.SamApiKey}" +
                       $"&status=open" +
                       $"&limit=20" +
                       $"&sort=-posted_date";

            var response = await HttpClient.GetFromJsonAsync<SamGrantResponse>(query);

            if (response?.Opportunities != null)
            {
                foreach (var opp in response.Opportunities)
                {
                    // Filter for significant opportunities (>$1M funding)
                    if (opp.EstimatedTotal >= 1000000m)
                    {
                        grants.Add(new GrantOpportunity
                        {
                            OpportunityId = opp.OpportunityId,
                            Title = opp.OpportunityTitle,
                            Description = opp.Description,
                            Agency = opp.AgencyCode,
                            FundingAmount = opp.EstimatedTotal,
                            Deadline = opp.CloseDate,
                            PostedDate = opp.PostedDate,
                            EligibilityCategory = opp.EligibilityCode,
                            FundingCategory = opp.FundingCategoryDescription
                        });
                    }
                }
            }

            // Cache results
            if (_settings.EnableCaching && grants.Count > 0)
            {
                var cacheKey = "sam_active_grants";
                var cacheOptions = new MemoryCacheEntryOptions()
                    .SetAbsoluteExpiration(TimeSpan.FromMinutes(_settings.CacheDurationMinutes));
                _cache.Set(cacheKey, grants, cacheOptions);
            }
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"SAM.gov API Request Failed: {ex.Message}");
        }
        catch (JsonException ex)
        {
            Console.WriteLine($"SAM.gov API JSON Parse Failed: {ex.Message}");
        }

        return grants;
    }

    private PoliSnap MapToGrantInsightPivot(GrantOpportunity grant)
    {
        var snap = new PoliSnap
        {
            Id = $"grant-{grant.OpportunityId}",
            Sku = $"GRN-ROI-{grant.FundingCategory}-{grant.OpportunityId}",
            Title = grant.Title,
            Type = "Economics",
            CreatedAt = grant.PostedDate,
            Sources = new List<Source>
            {
                new Source
                {
                    Name = $"SAM.gov ({grant.Agency})",
                    Url = $"https://sam.gov/opp/{grant.OpportunityId}"
                }
            },
            Metadata = new SnapMetadata
            {
                PolicyArea = "Grants & Funding",
                InsightType = "Grant Opportunity",
                Keywords = new List<string> { "Grants", "Funding", "Opportunities", "ROI", "Infrastructure" },
                LaymanSummary = $"${grant.FundingAmount / 1000000:N1}B grant opportunity: {grant.Title}. Deadline: {grant.Deadline:MMM d, yyyy}",
                Description = grant.Description
            },
            Elements = new List<SnapElement>
            {
                new SnapElement
                {
                    Id = "funding-hero",
                    Type = "Metric.CurrencyLarge",
                    Data = new Dictionary<string, object>
                    {
                        { "value", grant.FundingAmount },
                        { "label", "TOTAL FUNDING" },
                        { "currency", "USD" }
                    }
                },
                new SnapElement
                {
                    Id = "grant-details",
                    Type = "Narrative.Event.Details",
                    Data = new Dictionary<string, object>
                    {
                        { "title", "Grant Details" },
                        { "category", grant.FundingCategory },
                        { "deadline", grant.Deadline.ToString("MMM d, yyyy") },
                        { "eligibility", grant.EligibilityCategory },
                        { "posted", grant.PostedDate.ToString("MMM d, yyyy") }
                    }
                },
                new SnapElement
                {
                    Id = "grant-cta",
                    Type = "Interaction.Action.Card",
                    Data = new Dictionary<string, object>
                    {
                        { "title", "View Opportunity Details" },
                        { "label", "LEARN MORE" },
                        { "actionType", "link" },
                        { "actionPayload", $"https://sam.gov/opp/{grant.OpportunityId}" }
                    }
                },
                new SnapElement
                {
                    Id = "trust-thread",
                    Type = "Trust.Thread",
                    Data = new Dictionary<string, object>
                    {
                        { "referenceId", grant.OpportunityId },
                        { "oracleSource", "SAM.gov" },
                        { "verificationLevel", "Tier 3" },
                        { "agency", grant.Agency }
                    }
                }
            }
        };

        // Apply ACD enrichment
        ThreadDown(
            snap,
            intensity: 0.8,
            geographicDensity: 0.7,
            roiPotential: 0.85,
            derivationSummary: $"High-value grant opportunity: ${grant.FundingAmount:N0} for {grant.FundingCategory}"
        );

        return snap;
    }

    #region SAM.gov API Response Models

    private class SamGrantResponse
    {
        public List<SamOpportunity>? Opportunities { get; set; }
    }

    private class SamOpportunity
    {
        public string? OpportunityId { get; set; }
        public string? OpportunityTitle { get; set; }
        public string? Description { get; set; }
        public string? AgencyCode { get; set; }
        public decimal EstimatedTotal { get; set; }
        public DateTime PostedDate { get; set; }
        public DateTime CloseDate { get; set; }
        public string? EligibilityCode { get; set; }
        public string? FundingCategoryDescription { get; set; }
    }

    private class GrantOpportunity
    {
        public string? OpportunityId { get; set; }
        public string? Title { get; set; }
        public string? Description { get; set; }
        public string? Agency { get; set; }
        public decimal FundingAmount { get; set; }
        public DateTime Deadline { get; set; }
        public DateTime PostedDate { get; set; }
        public string? EligibilityCategory { get; set; }
        public string? FundingCategory { get; set; }
    }

    #endregion
}