using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Reflection;
using System.Text;
using System.Threading.Tasks;

namespace PoliTickIt.Ingestion.Services;

/// <summary>
/// Provides reflection-based auditing to detect when Provider implementations
/// drift from their documented Oracle Data Catalog specifications.
/// </summary>
public interface IOracleDriftDetector
{
    /// <summary>
    /// Audit all oracle providers for drift against catalog documentation
    /// </summary>
    Task<OracleDriftReport> AuditProvidersAsync();

    /// <summary>
    /// Check a specific provider for drift
    /// </summary>
    Task<OracleDriftReport> AuditProviderAsync(Type providerType);

    /// <summary>
    /// Generate suggested catalog updates based on current provider schemas
    /// </summary>
    Task<string> GenerateCatalogUpdatesAsync();
}

public class OracleDriftReport
{
    public bool HasDrift { get; set; }
    public List<PropertyDriftItem> Drifts { get; set; } = new();
    public List<string> MissingDocumentation { get; set; } = new();
    public string? ProviderName { get; set; }
    public DateTime ReportedAt { get; set; } = DateTime.UtcNow;
}

public class PropertyDriftItem
{
    public string? PropertyName { get; set; }
    public string? ExpectedInCatalog { get; set; }
    public string? ActualInCode { get; set; }
    public string? DriftType { get; set; } // "Missing", "TypeMismatch", "Removed"
}

/// <summary>
/// Implementation of Oracle Drift Detection using Reflection
/// </summary>
public class OracleDriftDetector : IOracleDriftDetector
{
    private readonly string _catalogPath;
    private readonly string _journalPath;

    public OracleDriftDetector(string catalogPath, string journalPath)
    {
        _catalogPath = catalogPath ?? throw new ArgumentNullException(nameof(catalogPath));
        _journalPath = journalPath ?? throw new ArgumentNullException(nameof(journalPath));
    }

    public async Task<OracleDriftReport> AuditProvidersAsync()
    {
        var combinedReport = new OracleDriftReport
        {
            ProviderName = "All Providers"
        };

        // Find all classes implementing IDataSourceProvider
        var providerType = typeof(IDataSourceProvider);
        var assembly = providerType.Assembly;
        var implementations = assembly.GetTypes()
            .Where(t => typeof(IDataSourceProvider).IsAssignableFrom(t) && !t.IsInterface && !t.IsAbstract)
            .ToList();

        foreach (var impl in implementations)
        {
            var report = await AuditProviderAsync(impl);
            if (report.HasDrift)
            {
                combinedReport.HasDrift = true;
                combinedReport.Drifts.AddRange(report.Drifts);
                combinedReport.MissingDocumentation.AddRange(report.MissingDocumentation);
            }
        }

        // Log to journal if drift detected
        if (combinedReport.HasDrift)
        {
            await LogDriftToJournalAsync(combinedReport);
        }

        return combinedReport;
    }

    public async Task<OracleDriftReport> AuditProviderAsync(Type providerType)
    {
        var report = new OracleDriftReport
        {
            ProviderName = providerType.Name
        };

        try
        {
            // Extract provider properties via reflection
            var properties = providerType.GetProperties(
                BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                .ToList();

            // Read catalog to find documented properties for this provider
            var catalogEntries = await ReadCatalogAsync();
            var providerCatalog = catalogEntries
                .Where(e => e.Provider.Equals(providerType.Name, StringComparison.OrdinalIgnoreCase))
                .ToList();

            // Check for drift
            foreach (var prop in properties)
            {
                var catalogEntry = providerCatalog
                    .FirstOrDefault(e => e.PropertyName.Equals(prop.Name, StringComparison.OrdinalIgnoreCase));

                if (catalogEntry == null)
                {
                    // New property not in catalog
                    report.Drifts.Add(new PropertyDriftItem
                    {
                        PropertyName = prop.Name,
                        ActualInCode = prop.PropertyType.Name,
                        ExpectedInCatalog = "NOT DOCUMENTED",
                        DriftType = "Missing"
                    });
                    report.HasDrift = true;
                }
                else if (catalogEntry.PropertyType != prop.PropertyType.Name)
                {
                    // Type mismatch
                    report.Drifts.Add(new PropertyDriftItem
                    {
                        PropertyName = prop.Name,
                        ExpectedInCatalog = catalogEntry.PropertyType,
                        ActualInCode = prop.PropertyType.Name,
                        DriftType = "TypeMismatch"
                    });
                    report.HasDrift = true;
                }
            }

            // Check for removed properties (documented but not in code)
            foreach (var catalogEntry in providerCatalog)
            {
                var codeProperty = properties
                    .FirstOrDefault(p => p.Name.Equals(catalogEntry.PropertyName, StringComparison.OrdinalIgnoreCase));

                if (codeProperty == null)
                {
                    report.Drifts.Add(new PropertyDriftItem
                    {
                        PropertyName = catalogEntry.PropertyName,
                        ExpectedInCatalog = catalogEntry.PropertyType,
                        ActualInCode = "REMOVED FROM CODE",
                        DriftType = "Removed"
                    });
                    report.HasDrift = true;
                }
            }
        }
        catch (Exception ex)
        {
            report.MissingDocumentation.Add($"Error analyzing {providerType.Name}: {ex.Message}");
            report.HasDrift = true;
        }

        return report;
    }

    public async Task<string> GenerateCatalogUpdatesAsync()
    {
        var sb = new StringBuilder();
        sb.AppendLine("# Suggested Oracle Data Catalog Updates");
        sb.AppendLine();
        sb.AppendLine($"Generated: {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}");
        sb.AppendLine();

        // Find all provider implementations
        var providerType = typeof(IDataSourceProvider);
        var assembly = providerType.Assembly;
        var implementations = assembly.GetTypes()
            .Where(t => typeof(IDataSourceProvider).IsAssignableFrom(t) && !t.IsInterface && !t.IsAbstract)
            .ToList();

        foreach (var impl in implementations)
        {
            sb.AppendLine($"## {impl.Name}");
            sb.AppendLine();

            var properties = impl.GetProperties(
                BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase)
                .ToList();

            sb.AppendLine("| Property | Type | Description |");
            sb.AppendLine("|---|---|---|");

            foreach (var prop in properties)
            {
                var summary = GetPropertySummary(prop);
                sb.AppendLine($"| {prop.Name} | {prop.PropertyType.Name} | {summary} |");
            }

            sb.AppendLine();
        }

        return await Task.FromResult(sb.ToString());
    }

    private async Task<List<CatalogEntry>> ReadCatalogAsync()
    {
        var entries = new List<CatalogEntry>();

        if (!File.Exists(_catalogPath))
            return entries;

        try
        {
            var content = await File.ReadAllTextAsync(_catalogPath);
            // Parse markdown table format (simplified parser)
            var lines = content.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.None);

            foreach (var line in lines)
            {
                if (line.StartsWith("|") && !line.Contains("---"))
                {
                    var parts = line.Split('|')
                        .Select(p => p.Trim())
                        .Where(p => !string.IsNullOrEmpty(p))
                        .ToList();

                    if (parts.Count >= 3)
                    {
                        entries.Add(new CatalogEntry
                        {
                            Provider = parts[0],
                            PropertyName = parts[1],
                            PropertyType = parts[2]
                        });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reading catalog: {ex.Message}");
        }

        return entries;
    }

    private async Task LogDriftToJournalAsync(OracleDriftReport report)
    {
        try
        {
            var entry = new StringBuilder();
            entry.AppendLine($"\n- [{DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}] DRIFT DETECTED: {report.ProviderName}");
            entry.AppendLine($"  - Issues Found: {report.Drifts.Count}");
            
            foreach (var drift in report.Drifts)
            {
                entry.AppendLine($"    - [{drift.DriftType}] {drift.PropertyName}: Expected {drift.ExpectedInCatalog}, Got {drift.ActualInCode}");
            }

            if (File.Exists(_journalPath))
            {
                await File.AppendAllTextAsync(_journalPath, entry.ToString());
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error logging drift: {ex.Message}");
        }
    }

    private string GetPropertySummary(PropertyInfo prop)
    {
        // Try to extract XML documentation summary
        var xmlAttribute = prop.GetCustomAttribute<System.ComponentModel.DescriptionAttribute>();
        return xmlAttribute?.Description ?? "See provider implementation";
    }

    private class CatalogEntry
    {
        public string? Provider { get; set; }
        public string? PropertyName { get; set; }
        public string? PropertyType { get; set; }
    }
}
