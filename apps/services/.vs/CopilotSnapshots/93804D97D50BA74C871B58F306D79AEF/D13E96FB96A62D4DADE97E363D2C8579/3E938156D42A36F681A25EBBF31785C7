using PoliTickIt.Ingestion.Providers;

namespace PoliTickIt.Api.Tests.Providers;

public class FecProviderTests
{
    [Fact]
    public async Task FetchLatestSnapsAsync_ShouldReturnSnaps()
    {
        // Arrange
        var provider = new FecProvider();

        // Act
        var result = await provider.FetchLatestSnapsAsync();

        // Assert
        Assert.NotNull(result);
        Assert.NotEmpty(result);
    }

    [Fact]
    public async Task FetchLatestSnapsAsync_ShouldReturnSnapsWithValidStructure()
    {
        // Arrange
        var provider = new FecProvider();

        // Act
        var result = await provider.FetchLatestSnapsAsync();

        // Assert
        var snaps = result.ToList();
        Assert.NotEmpty(snaps);

        var firstSnap = snaps.First();
        Assert.NotNull(firstSnap.Id);
        Assert.NotEmpty(firstSnap.Id);
        Assert.NotNull(firstSnap.Sku);
        Assert.NotEmpty(firstSnap.Sku);
        Assert.NotNull(firstSnap.Title);
        Assert.NotEmpty(firstSnap.Title);
        Assert.NotNull(firstSnap.Type);
        Assert.NotEmpty(firstSnap.Type);
        Assert.NotNull(firstSnap.Sources);
        Assert.NotEmpty(firstSnap.Sources);
        Assert.NotNull(firstSnap.Metadata);
    }

    [Fact]
    public async Task FetchLatestSnapsAsync_EachSnapShouldHaveUniqueId()
    {
        // Arrange
        var provider = new FecProvider();

        // Act
        var result1 = await provider.FetchLatestSnapsAsync();
        var result2 = await provider.FetchLatestSnapsAsync();

        // Assert
        var ids1 = result1.Select(s => s.Id).ToList();
        var ids2 = result2.Select(s => s.Id).ToList();

        // IDs should be different between calls due to Guid generation
        Assert.NotEqual(ids1, ids2);
    }

    [Fact]
    public void ProviderName_ShouldReturnFecGov()
    {
        // Arrange
        var provider = new FecProvider();

        // Act
        var name = provider.ProviderName;

        // Assert
        Assert.Equal("FEC.gov", name);
    }
}
