using Microsoft.AspNetCore.Mvc.Testing;
using Microsoft.Extensions.DependencyInjection;
using PoliTickIt.Domain.Interfaces;
using PoliTickIt.Infrastructure.Persistence;

namespace PoliTickIt.Api.Tests;

public class ApiWebApplicationFactory : WebApplicationFactory<Program>
{
    protected override void ConfigureWebHost(IWebHostBuilder builder)
    {
        builder.ConfigureServices(services =>
        {
            // Replace the snap repository with a fresh instance for each test
            var descriptor = services.FirstOrDefault(d => d.ServiceType == typeof(ISnapRepository));
            if (descriptor != null)
            {
                services.Remove(descriptor);
            }

            services.AddSingleton<ISnapRepository, InMemorySnapRepository>();
        });

        builder.UseEnvironment("Development");
    }
}
