using PoliTickIt.Domain.Models;
using PoliTickIt.Infrastructure.Persistence;

namespace PoliTickIt.Api.Tests.Infrastructure;

public class InMemorySnapRepositoryTests
{
    [Fact]
    public async Task SaveSnapAsync_ShouldSaveSnap()
    {
        // Arrange
        var repository = new InMemorySnapRepository();
        var snap = new PoliSnap
        {
            Id = "test-1",
            Sku = "TEST-SKU",
            Title = "Test Snap",
            Type = "TestType",
            CreatedAt = DateTime.UtcNow
        };

        // Act
        await repository.SaveSnapAsync(snap);

        // Assert
        var retrieved = await repository.GetSnapByIdAsync("test-1");
        Assert.NotNull(retrieved);
        Assert.Equal("test-1", retrieved.Id);
        Assert.Equal("TEST-SKU", retrieved.Sku);
    }

    [Fact]
    public async Task SaveSnapsAsync_ShouldSaveMultipleSnaps()
    {
        // Arrange
        var repository = new InMemorySnapRepository();
        var snaps = new List<PoliSnap>
        {
            new PoliSnap { Id = "1", Sku = "S1", Title = "T1", Type = "Ty1", CreatedAt = DateTime.UtcNow },
            new PoliSnap { Id = "2", Sku = "S2", Title = "T2", Type = "Ty2", CreatedAt = DateTime.UtcNow },
            new PoliSnap { Id = "3", Sku = "S3", Title = "T3", Type = "Ty3", CreatedAt = DateTime.UtcNow }
        };

        // Act
        await repository.SaveSnapsAsync(snaps);

        // Assert
        var allSnaps = await repository.GetAllSnapsAsync();
        Assert.NotNull(allSnaps);
        Assert.Equal(3, allSnaps.Count());
    }

    [Fact]
    public async Task GetAllSnapsAsync_ShouldReturnEmptyListWhenNoSnaps()
    {
        // Arrange
        var repository = new InMemorySnapRepository();

        // Act
        var result = await repository.GetAllSnapsAsync();

        // Assert
        Assert.NotNull(result);
        Assert.Empty(result);
    }

    [Fact]
    public async Task GetSnapByIdAsync_ShouldReturnNullWhenNotFound()
    {
        // Arrange
        var repository = new InMemorySnapRepository();

        // Act
        var result = await repository.GetSnapByIdAsync("non-existent");

        // Assert
        Assert.Null(result);
    }

    [Fact]
    public async Task GetAllSnapsAsync_ShouldReturnAllSavedSnaps()
    {
        // Arrange
        var repository = new InMemorySnapRepository();
        var snap1 = new PoliSnap { Id = "1", Sku = "S1", Title = "T1", Type = "Ty1", CreatedAt = DateTime.UtcNow };
        var snap2 = new PoliSnap { Id = "2", Sku = "S2", Title = "T2", Type = "Ty2", CreatedAt = DateTime.UtcNow };

        // Act
        await repository.SaveSnapAsync(snap1);
        await repository.SaveSnapAsync(snap2);
        var result = await repository.GetAllSnapsAsync();

        // Assert
        Assert.Equal(2, result.Count());
    }

    [Fact]
    public async Task SaveSnapAsync_ShouldOverwriteExistingSnap()
    {
        // Arrange
        var repository = new InMemorySnapRepository();
        var snap1 = new PoliSnap { Id = "1", Sku = "S1", Title = "Original", Type = "Ty1", CreatedAt = DateTime.UtcNow };
        var snap2 = new PoliSnap { Id = "1", Sku = "S1", Title = "Updated", Type = "Ty1", CreatedAt = DateTime.UtcNow };

        // Act
        await repository.SaveSnapAsync(snap1);
        await repository.SaveSnapAsync(snap2);
        var result = await repository.GetSnapByIdAsync("1");

        // Assert
        Assert.NotNull(result);
        Assert.Equal("Updated", result.Title);
    }
}
