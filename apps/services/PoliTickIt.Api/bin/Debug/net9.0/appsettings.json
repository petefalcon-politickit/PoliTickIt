{
  "OracleSettings": {
    "Fec": {
      "ApiKey": "YOUR_FEC_API_KEY_HERE",
      "BaseUrl": "https://api.open.fec.gov/v1",
      "TimeoutSeconds": 30,
      "EnableCaching": true,
      "CacheDurationMinutes": 60
    },
    "Congress": {
      "ApiKey": "YOUR_CONGRESS_API_KEY_HERE",
      "BaseUrl": "https://api.congress.gov/v3",
      "TimeoutSeconds": 30,
      "EnableCaching": true,
      "CacheDurationMinutes": 120
    },
    "Grants": {
      "SamApiKey": "YOUR_SAM_API_KEY_HERE",
      "GrantsApiKey": "YOUR_GRANTS_API_KEY_HERE",
      "SamBaseUrl": "https://api.sam.gov/opportunities/v2",
      "TimeoutSeconds": 30,
      "EnableCaching": true,
      "CacheDurationMinutes": 60
    },
    "Census": {
      "ApiKey": "YOUR_CENSUS_API_KEY_HERE",
      "BaseUrl": "https://api.census.gov/data",
      "TimeoutSeconds": 30,
      "EnableCaching": true,
      "CacheDurationMinutes": 1440
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
